# 🐺 DHEEB Coaching System - Environment Variables

# Telegram Bot
# كيف تحصل على Token:
# 1. فتح Telegram
# 2. ابحث عن: @BotFather
# 3. اكتب: /newbot
# 4. اتبع التعليمات
# 5. نسخ Token من الرد
TELEGRAM_BOT_TOKEN=your_token_here_from_botfather

# Telegram Chat ID
# كيف تحصل على Chat ID:
# 1. أرسل رسالة لـ @userinfobot
# 2. سيعطيك Chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# Notion API Key
# كيف تحصل على Key:
# 1. اذهب: https://www.notion.so/my-integrations
# 2. اضغط: Create new integration
# 3. اكتب الاسم: DHEEB Coach
# 4. اضغط: Create integration
# 5. نسخ Token من الصفحة
NOTION_API_KEY=ntn_your_key_here

# (اختياري) Notion Database IDs
# إذا كنت تريد استخدام databases معينة
NOTION_TRADES_DB_ID=your_database_id
NOTION_PERFORMANCE_DB_ID=your_database_id
NOTION_PSYCHOLOGY_DB_ID=your_database_id

# (اختياري) Trading Configuration
MAX_TRADES_PER_DAY=2
DAILY_LOSS_LIMIT=600
MIN_RRR=2
MAX_RISK_PER_TRADE=2

# (اختياري) Sessions Timezone
TIMEZONE=Asia/Riyadh
LONDON_OPEN=08:00
LONDON_CLOSE=12:00
ASIA_OPEN=00:00
ASIA_CLOSE=06:00
NEWYORK_OPEN=13:00
NEWYORK_CLOSE=21:00
