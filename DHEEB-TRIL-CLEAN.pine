//@version=5
indicator("DHEEB TRIL System", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// =============================================================================
// INPUTS - KILL ZONES
// =============================================================================

// Session Colors
asiaColor = input.color(color.new(#14B8A6, 80), "Asia Color")
londonColor = input.color(color.new(#F59E0B, 80), "London Color")
nyamColor = input.color(color.new(#EF4444, 80), "NY AM Color")
nyluColor = input.color(color.new(#EAB308, 80), "NY Lunch Color")
nypmColor = input.color(color.new(#8B5CF6, 80), "NY PM Color")

// Kill Zone Sessions
showAsia = input.bool(true, "Show Asia Kill Zone")
showLondon = input.bool(true, "Show London Kill Zone")
showNYAM = input.bool(true, "Show NY AM Kill Zone")
showNYLunch = input.bool(true, "Show NY Lunch Kill Zone")
showNYPM = input.bool(true, "Show NY PM Kill Zone")

// SMC Options
showPDH = input.bool(true, "Show PDH")
showPDL = input.bool(true, "Show PDL")
showFVG = input.bool(true, "Show FVG")
showOB = input.bool(true, "Show Order Blocks")

// =============================================================================
// SESSION DETECTION
// =============================================================================

inAsia() => not na(time(session("2000-0000", "America/New_York")))
inLondon() => not na(time(session("0200-0500", "America/New_York")))
inNYAM() => not na(time(session("0930-1100", "America/New_York")))
inNYLunch() => not na(time(session("1200-1300", "America/New_York")))
inNYPM() => not na(time(session("1330-1600", "America/New_York")))

currentKillZone = switch
    inNYPM() => "NY PM"
    inNYLunch() => "NY Lunch"
    inNYAM() => "NY AM"
    inLondon() => "London"
    inAsia() => "Asia"
    => "Off Hours"

killzoneColor = switch currentKillZone
    "Asia" => asiaColor
    "London" => londonColor
    "NY AM" => nyamColor
    "NY Lunch" => nyluColor
    "NY PM" => nypmColor
    => color.new(color.gray, 90)

// =============================================================================
// BACKGROUND
// =============================================================================

bgcolor(color.new(killzoneColor, 50))

// =============================================================================
// PDH/PDL
// =============================================================================

[pdh, pdl] = request.security(syminfo.tickerid, "D", [high[1], low[1]])

plot(showPDH and not na(pdh), "PDH", pdh, color=color.orange, linewidth=2, style=plot.style_circles, trackprice=true)
plot(showPDL and not na(pdl), "PDL", pdl, color=color.blue, linewidth=2, style=plot.style_circles, trackprice=true)

// =============================================================================
// FAIR VALUE GAP
// =============================================================================

bullFvg = false
bearFvg = false

if showFVG and bar_index > 2
    fvgUpper = math.max(high[1], high[2])
    fvgLower = math.min(low[1], low[2])
    bullFvg := close > open and low < fvgLower
    bearFvg := close < open and high > fvgUpper

// Plot FVG Labels
plotshape(bullFvg, title="Bull FVG", location=location.belowbar, color=color.green, style=shape.labelup, text="FVG")
plotshape(bearFvg, title="Bear FVG", location=location.abovebar, color=color.red, style=shape.labeldown, text="FVG")

// =============================================================================
// ORDER BLOCKS (Simplified)
// =============================================================================

var float lastBullOB = na
var float lastBearOB = na

if showOB and bar_index > 5
    // Bullish OB - green candle before big drop
    if close[1] > open[1] and close < open[1] and close[2] < open[2]
        lastBullOB := low[1]
    // Bearish OB - red candle before big rise
    if close[1] < open[1] and close > open[1] and close[2] > open[2]
        lastBearOB := high[1]

plot(showOB and not na(lastBullOB), "Bull OB", lastBullOB, color=color.green, linewidth=2, style=plot.style_line)
plot(showOB and not na(lastBearOB), "Bear OB", lastBearOB, color=color.red, linewidth=2, style=plot.style_line)

// =============================================================================
// INFO TABLE
// =============================================================================

var table infoTable = table.new(position.top_right, 4, 8, bgcolor=color.new(#1E1E1E, 90))

if barstate.islast
    // Session
    table.cell(infoTable, 0, 0, "SESSION", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, currentKillZone, text_color=killzoneColor, text_size=size.small, text_halign=text.align_center)
    
    // Price
    table.cell(infoTable, 0, 1, "PRICE", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 1, str.tostring(close, "#.##"), text_color=color.white, text_size=size.small)
    
    // PDH
    table.cell(infoTable, 0, 2, "PDH", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(pdh, "#.##"), text_color=color.orange, text_size=size.small)
    
    // PDL
    table.cell(infoTable, 2, 2, "PDL", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 3, 2, str.tostring(pdl, "#.##"), text_color=color.blue, text_size=size.small)
    
    // Status
    table.cell(infoTable, 0, 3, "STATUS", text_color=color.white, text_size=size.small)
    statusText = inNYAM() or inNYPM() or inLondon() or inAsia() ? "ACTIVE" : "WAIT"
    statusColor = inNYAM() or inNYPM() or inLondon() or inAsia() ? color.green : color.gray
    table.cell(infoTable, 1, 3, statusText, text_color=statusColor, text_size=size.small)
    
    // Instructions
    table.cell(infoTable, 0, 5, "RULES:", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 0, 6, "1. RRR >= 2.0", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 0, 7, "2. Kill Zone Only", text_color=color.gray, text_size=size.tiny)

// =============================================================================
// ALERTS
// =============================================================================

alertcondition(inNYAM() or inNYPM() or inLondon(), title="Kill Zone Alert", message="Entering Kill Zone")
alertcondition(bullFvg, title="Bullish FVG", message="Bullish FVG formed")
alertcondition(bearFvg, title="Bearish FVG", message="Bearish FVG formed")
