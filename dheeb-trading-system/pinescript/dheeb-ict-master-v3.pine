// ═══════════════════════════════════════════════════════════════════════════
// 🐺 DHEEB ICT MASTER STRATEGY v3.0
// دمج شامل لمفاهيم ICT مع التنفيذ التلقائي عبر Tradovate
//
// المصادر المدمجة:
//   1. Mxwll Suite → Market Structure (BoS/CHoCH), FVG, Swing OB, Fibs, AOI
//   2. ICT Killzones & Pivots [TFO] → Killzones, Session Pivots, DWM Levels
//   3. ICT Immediate Rebalance [LuxAlgo] → IR, BSL/SSL, OB/BB, Liq Voids
//
// الإخراج: Webhook signals → Dheeb Execution Engine → Tradovate
// ═══════════════════════════════════════════════════════════════════════════

//@version=6
strategy("🐺 Dheeb ICT Master v3", overlay=true,
     default_qty_type=strategy.fixed, default_qty_value=1,
     max_labels_count=500, max_lines_count=500, max_boxes_count=500,
     max_bars_back=500, calc_on_every_tick=false,
     process_orders_on_close=true)

// ═══════════════════════════════════════════════════════════════
//  ⚙️ INPUTS — الإعدادات
// ═══════════════════════════════════════════════════════════════

// ─── Webhook ───
grpWH       = "🐺 Webhook Settings"
whSecret    = input.string("change_me",    "Webhook Secret",        group=grpWH)
whSymbol    = input.string("NQH6",         "Contract Symbol",       group=grpWH)
whQty       = input.int(1,                 "Default Quantity",      group=grpWH, minval=1)
enableAuto  = input.bool(true,             "Enable Auto Signals",   group=grpWH)

// ─── Colors ───
grpCOL      = "🎨 Colors"
bullC       = input.color(#14D990, "Bull Color", group=grpCOL, inline="c1")
bearC       = input.color(#F24968, "Bear Color", group=grpCOL, inline="c1")
fvgCol      = input.color(#F2B807, "FVG Color",  group=grpCOL, inline="c2")
fvgTra      = input.int(80, "FVG Transparency", group=grpCOL, minval=0, maxval=100)

// ─── Market Structure (Mxwll) ───
grpMS       = "📊 Market Structure"
showInt     = input.bool(true,  "Show Internals (BoS/CHoCH)", group=grpMS)
intSens     = input.int(3,     "Internal Sensitivity", options=[3,5,8], group=grpMS)
showExt     = input.bool(true,  "Show Externals (BoS/CHoCH)", group=grpMS)
extSens     = input.int(25,    "External Sensitivity", options=[10,25,50], group=grpMS)

// ─── Fair Value Gaps ───
grpFVG      = "📐 Fair Value Gaps"
showFVG     = input.bool(true,  "Show FVGs",              group=grpFVG)
contractFVG = input.bool(false, "Contract Violated FVGs", group=grpFVG)

// ─── Order Blocks ───
grpOB       = "🧱 Order Blocks"
showOB      = input.bool(true,  "Show Swing Order Blocks", group=grpOB)
obCount     = input.int(10,    "Max OB Count",            group=grpOB, minval=1)
obSwingLen  = input.int(7,     "OB Swing Length",          group=grpOB, minval=3)

// ─── Liquidity ───
grpLIQ      = "💧 Liquidity"
showLiq     = input.bool(true,  "Show BSL/SSL Levels",    group=grpLIQ)
liqLen      = input.int(7,     "Liquidity Detection Len", group=grpLIQ, minval=3)

// ─── Killzones (TFO) ───
grpKZ       = "🕐 ICT Killzones"
showKZ      = input.bool(true,  "Show Killzone Boxes",    group=grpKZ)
kzAsiaCol   = input.color(color.new(color.blue, 85),   "Asia",    group=grpKZ, inline="kz1")
kzLdnCol    = input.color(color.new(color.red, 85),    "London",  group=grpKZ, inline="kz1")
kzNyAmCol   = input.color(color.new(#089981, 85),      "NY AM",   group=grpKZ, inline="kz2")
kzNyLuCol   = input.color(color.new(color.yellow, 90), "Lunch",   group=grpKZ, inline="kz2")
kzNyPmCol   = input.color(color.new(color.purple, 85), "NY PM",   group=grpKZ, inline="kz3")

// ─── Session Pivots (TFO) ───
grpPV       = "📍 Session Pivots"
showPivots  = input.bool(true,  "Show KZ Pivot H/L", group=grpPV)

// ─── DWM Levels ───
grpDWM      = "📅 Daily/Weekly/Monthly"
showDOpen   = input.bool(false, "Daily Open",   group=grpDWM)
showWOpen   = input.bool(false, "Weekly Open",  group=grpDWM)
showPDH     = input.bool(true,  "Prev Day H/L", group=grpDWM)

// ─── Auto Fibs ───
grpFIB      = "📏 Auto Fibonacci"
showFibs    = input.bool(true, "Show Auto Fibs", group=grpFIB)

// ─── Immediate Rebalance (LuxAlgo) ───
grpIR       = "⚡ Immediate Rebalance"
showIR      = input.bool(true,  "Show Immediate Rebalances", group=grpIR)
irConfirm   = input.int(2,     "Confirmation Bars",         group=grpIR, minval=1, maxval=5)

// ─── Entry Logic ───
grpEntry    = "🎯 Entry Rules"
minConfl    = input.int(2,     "Min Confluence for Entry",  group=grpEntry, minval=1, maxval=5)
useKZfilter = input.bool(true, "Only Trade in Killzones",   group=grpEntry)
riskPts     = input.float(20,  "Stop Loss (points)",        group=grpEntry, minval=5)
rrRatio     = input.float(2.0, "Risk:Reward Ratio",         group=grpEntry, minval=1.0, step=0.5)
maxTrades   = input.int(4,     "Max Trades/Day",            group=grpEntry, minval=1)
noFriPM     = input.bool(true, "No Trading Friday 2PM+",    group=grpEntry)


// ═══════════════════════════════════════════════════════════════
//  🕐 KILLZONES — من TFO
// ═══════════════════════════════════════════════════════════════

nyH  = hour(time, "America/New_York")
nyM  = minute(time, "America/New_York")
nyT  = nyH * 60 + nyM

inAsia   = (nyH >= 20 and nyH <= 23) or (nyH >= 0 and nyH < 0)
inLondon = nyH >= 2 and nyH < 5
inNyAM   = (nyH == 9 and nyM >= 30) or (nyH == 10 and nyM <= 59)
inNyLu   = nyH == 12 or (nyH == 13 and nyM < 30)
inNyPM   = (nyH == 13 and nyM >= 30) or (nyH >= 14 and nyH < 16)

inActiveKZ = inLondon or inNyAM or inNyPM
inAnyKZ    = inAsia or inLondon or inNyAM or inNyLu or inNyPM

// Killzone background colors
bgcolor(showKZ and inAsia   ? kzAsiaCol  : na, title="Asia KZ")
bgcolor(showKZ and inLondon ? kzLdnCol   : na, title="London KZ")
bgcolor(showKZ and inNyAM   ? kzNyAmCol  : na, title="NY AM KZ")
bgcolor(showKZ and inNyLu   ? kzNyLuCol  : na, title="NY Lunch KZ")
bgcolor(showKZ and inNyPM   ? kzNyPmCol  : na, title="NY PM KZ")

// Friday PM block
isFriday  = dayofweek(time, "America/New_York") == dayofweek.friday
isFriPM   = isFriday and nyH >= 14
noTradeKZ = useKZfilter and not inActiveKZ
noTradeFri = noFriPM and isFriPM


// ═══════════════════════════════════════════════════════════════
//  📊 MARKET STRUCTURE — من Mxwll Suite
//  BoS, CHoCH, Internal & External Structure
// ═══════════════════════════════════════════════════════════════

// ─── Pivot Detection ───
calcPivots(int length) =>
    var int trend = 0
    float topSw = 0.0
    float botSw = 0.0
    if bar_index > length + 1
        up = ta.highest(high, length)
        dn = ta.lowest(low, length)
        cHi = high[length]
        cLo = low[length]
        trend := cHi > up[1] ? 0 : cLo < dn[1] ? 1 : trend
        topSw := trend == 0 and trend[1] != 0 ? cHi : 0
        botSw := trend == 1 and trend[1] != 1 ? cLo : 0
    [topSw, botSw]

[extUp, extDn] = calcPivots(extSens)
[intUp, intDn] = calcPivots(intSens)

// ─── External Structure (BoS / CHoCH) ───
var float extHigh = na
var float extLow  = na
var int   extDir  = 0

// Track external swing points
if extUp != 0
    extHigh := extUp
if extDn != 0
    extLow := extDn

// ─── Structure State ───
var int msBias = 0  // 1 = bullish, -1 = bearish
bullBOS  = ta.crossover(close, extHigh) and extDir <= 0
bearBOS  = ta.crossunder(close, extLow) and extDir >= 0
bullCHoCH = ta.crossover(close, extHigh) and extDir < 0
bearCHoCH = ta.crossunder(close, extLow) and extDir > 0

if bullBOS or bullCHoCH
    extDir := 1
    msBias := 1
if bearBOS or bearCHoCH
    extDir := -1
    msBias := -1

// Visual markers
plotshape(showExt and bullCHoCH, "Bull CHoCH", shape.labelup,   location.belowbar, bullC, text="CHoCH", size=size.tiny)
plotshape(showExt and bearCHoCH, "Bear CHoCH", shape.labeldown, location.abovebar, bearC, text="CHoCH", size=size.tiny)
plotshape(showExt and bullBOS and not bullCHoCH, "Bull BoS", shape.labelup,   location.belowbar, bullC, text="BoS", size=size.tiny)
plotshape(showExt and bearBOS and not bearCHoCH, "Bear BoS", shape.labeldown, location.abovebar, bearC, text="BoS", size=size.tiny)

// ─── Internal Structure ───
var float intHigh = na
var float intLow  = na
var int   intDir  = 0

if intUp != 0
    intHigh := intUp
if intDn != 0
    intLow := intDn

intBullBOS  = ta.crossover(close, intHigh)  and intDir <= 0
intBearBOS  = ta.crossunder(close, intLow)  and intDir >= 0

if intBullBOS
    intDir := 1
if intBearBOS
    intDir := -1

plotshape(showInt and intBullBOS, "Int Bull", shape.triangleup,   location.belowbar, color.new(bullC, 40), size=size.tiny)
plotshape(showInt and intBearBOS, "Int Bear", shape.triangledown, location.abovebar, color.new(bearC, 40), size=size.tiny)


// ═══════════════════════════════════════════════════════════════
//  📐 FVG — Fair Value Gaps (Mxwll)
// ═══════════════════════════════════════════════════════════════

bullFVG = low > high[2]
bearFVG = high < low[2]

var box[] fvgBoxUp = array.new_box()
var box[] fvgBoxDn = array.new_box()

fvgColor = color.new(fvgCol, fvgTra)

if showFVG
    if bullFVG
        fvgBoxUp.unshift(box.new(bar_index - 1, low, bar_index + 20, high[2],
             border_color=fvgColor, bgcolor=fvgColor))

    if bearFVG
        fvgBoxDn.unshift(box.new(bar_index - 1, low[2], bar_index + 20, high,
             border_color=fvgColor, bgcolor=fvgColor))

    // Mitigate FVGs
    if fvgBoxUp.size() > 0
        for i = fvgBoxUp.size() - 1 to 0
            bx = fvgBoxUp.get(i)
            if low <= bx.get_bottom()
                bx.delete()
                fvgBoxUp.remove(i)
            else
                bx.set_right(bar_index + 5)
                if contractFVG and low < bx.get_top()
                    bx.set_top(low)

    if fvgBoxDn.size() > 0
        for i = fvgBoxDn.size() - 1 to 0
            bx = fvgBoxDn.get(i)
            if high >= bx.get_top()
                bx.delete()
                fvgBoxDn.remove(i)
            else
                bx.set_right(bar_index + 5)
                if contractFVG and high > bx.get_bottom()
                    bx.set_bottom(high)

    // Limit count
    if fvgBoxUp.size() > 30
        fvgBoxUp.pop().delete()
    if fvgBoxDn.size() > 30
        fvgBoxDn.pop().delete()


// ═══════════════════════════════════════════════════════════════
//  🧱 ORDER BLOCKS — من Mxwll + LuxAlgo
// ═══════════════════════════════════════════════════════════════

var box[] bullOBs = array.new_box()
var box[] bearOBs = array.new_box()

// Swing-based OB detection (LuxAlgo method)
var int obOS = 0
obUpper = ta.highest(high, obSwingLen)
obLower = ta.lowest(low, obSwingLen)

obOS := high[obSwingLen] > obUpper ? 0 : low[obSwingLen] < obLower ? 1 : obOS

// Bullish OB: found at swing low
bullOBsignal = obOS == 1 and obOS[1] != 1

// Bearish OB: found at swing high
bearOBsignal = obOS == 0 and obOS[1] != 0

if showOB
    if bullOBsignal
        // Find the lowest candle in the swing
        loIdx = bar_index - obSwingLen
        loLow  = low[obSwingLen]
        loHigh = high[obSwingLen]
        bullOBs.unshift(box.new(loIdx, loHigh, bar_index + 10, loLow,
             border_color=color.new(color.blue, 75),
             bgcolor=color.new(color.blue, 92),
             text="OB+", text_color=color.new(bullC, 50), text_size=size.tiny))

    if bearOBsignal
        hiIdx = bar_index - obSwingLen
        hiHigh = high[obSwingLen]
        hiLow  = low[obSwingLen]
        bearOBs.unshift(box.new(hiIdx, hiHigh, bar_index + 10, hiLow,
             border_color=color.new(color.red, 75),
             bgcolor=color.new(color.red, 92),
             text="OB-", text_color=color.new(bearC, 50), text_size=size.tiny))

    // Mitigate OBs
    if bullOBs.size() > 0
        for i = bullOBs.size() - 1 to 0
            bx = bullOBs.get(i)
            if close < bx.get_bottom()
                bx.delete()
                bullOBs.remove(i)
            else
                bx.set_right(bar_index + 5)

    if bearOBs.size() > 0
        for i = bearOBs.size() - 1 to 0
            bx = bearOBs.get(i)
            if close > bx.get_top()
                bx.delete()
                bearOBs.remove(i)
            else
                bx.set_right(bar_index + 5)

    // Limit
    if bullOBs.size() > obCount
        bullOBs.pop().delete()
    if bearOBs.size() > obCount
        bearOBs.pop().delete()


// ═══════════════════════════════════════════════════════════════
//  💧 LIQUIDITY — BSL/SSL (LuxAlgo)
// ═══════════════════════════════════════════════════════════════

// Simple equal highs/lows detection for BSL/SSL
ph = ta.pivothigh(high, liqLen, 1)
pl = ta.pivotlow(low, liqLen, 1)

var float bslLevel = na
var float sslLevel = na
var int   bslBar   = na
var int   sslBar   = na

if showLiq
    if not na(ph)
        if not na(bslLevel) and math.abs(ph - bslLevel) < ta.atr(14) * 0.15
            // Equal highs → BSL
            bslLevel := math.max(ph, bslLevel)
        else
            bslLevel := ph
        bslBar := bar_index - 1

    if not na(pl)
        if not na(sslLevel) and math.abs(pl - sslLevel) < ta.atr(14) * 0.15
            // Equal lows → SSL
            sslLevel := math.min(pl, sslLevel)
        else
            sslLevel := pl
        sslBar := bar_index - 1

// BSL/SSL sweep detection
bslSwept = not na(bslLevel) and high > bslLevel and close < bslLevel
sslSwept = not na(sslLevel) and low < sslLevel  and close > sslLevel

plotshape(showLiq and bslSwept, "BSL Sweep", shape.xcross, location.abovebar, bearC, size=size.small)
plotshape(showLiq and sslSwept, "SSL Sweep", shape.xcross, location.belowbar, bullC, size=size.small)

// Draw BSL/SSL lines
plot(showLiq and not na(bslLevel) ? bslLevel : na, "BSL", color.new(bearC, 60), style=plot.style_circles)
plot(showLiq and not na(sslLevel) ? sslLevel : na, "SSL", color.new(bullC, 60), style=plot.style_circles)


// ═══════════════════════════════════════════════════════════════
//  ⚡ IMMEDIATE REBALANCE — من LuxAlgo
// ═══════════════════════════════════════════════════════════════

// Bullish IR: candle dips below prev candle high then closes above it
bullIR = low < high[2] and low > close[2] and close > high[2] and close[1] > high[2] and close > close[1]
// Bearish IR: candle spikes above prev candle low then closes below
bearIR = high > low[2] and high < close[2] and close < low[2] and close[1] < low[2] and close < close[1]

plotshape(showIR and bullIR, "Bull IR", shape.diamond, location.belowbar, bullC, text="IR", size=size.tiny)
plotshape(showIR and bearIR, "Bear IR", shape.diamond, location.abovebar, bearC, text="IR", size=size.tiny)


// ═══════════════════════════════════════════════════════════════
//  📅 PDH/PDL + DWM (TFO)
// ═══════════════════════════════════════════════════════════════

[pdH, pdL] = request.security(syminfo.tickerid, "D", [high[1], low[1]])
plot(showPDH ? pdH : na, "PDH", color.new(color.aqua, 40), style=plot.style_stepline)
plot(showPDH ? pdL : na, "PDL", color.new(color.aqua, 40), style=plot.style_stepline)


// ═══════════════════════════════════════════════════════════════
//  📏 AUTO FIBONACCI — من Mxwll
// ═══════════════════════════════════════════════════════════════

var float fibHigh = na
var float fibLow  = na

if extUp != 0
    fibHigh := extUp
if extDn != 0
    fibLow := extDn

fibRange  = nz(fibHigh) - nz(fibLow)
fib236    = nz(fibLow) + fibRange * 0.236
fib382    = nz(fibLow) + fibRange * 0.382
fib500    = nz(fibLow) + fibRange * 0.500
fib618    = nz(fibLow) + fibRange * 0.618
fib786    = nz(fibLow) + fibRange * 0.786

plot(showFibs and fibRange > 0 ? fib236 : na, ".236", color.gray,   style=plot.style_cross)
plot(showFibs and fibRange > 0 ? fib382 : na, ".382", color.lime,   style=plot.style_cross)
plot(showFibs and fibRange > 0 ? fib500 : na, ".500", color.yellow, style=plot.style_cross)
plot(showFibs and fibRange > 0 ? fib618 : na, ".618", color.orange, style=plot.style_cross)
plot(showFibs and fibRange > 0 ? fib786 : na, ".786", color.red,    style=plot.style_cross)


// ═══════════════════════════════════════════════════════════════
//  🎯 CONFLUENCE SCORING — نظام التقييم المتكامل
// ═══════════════════════════════════════════════════════════════

// Count confluence factors for entry quality
var int bullScore = 0
var int bearScore = 0

bullScore := 0
bearScore := 0

// 1. Market Structure bias
if msBias == 1
    bullScore += 1
if msBias == -1
    bearScore += 1

// 2. FVG present
nearBullFVG = false
nearBearFVG = false
if fvgBoxUp.size() > 0
    for i = 0 to math.min(fvgBoxUp.size() - 1, 4)
        bx = fvgBoxUp.get(i)
        if close > bx.get_bottom() and close < bx.get_top() + ta.atr(14)
            nearBullFVG := true
            break

if fvgBoxDn.size() > 0
    for i = 0 to math.min(fvgBoxDn.size() - 1, 4)
        bx = fvgBoxDn.get(i)
        if close < bx.get_top() and close > bx.get_bottom() - ta.atr(14)
            nearBearFVG := true
            break

if nearBullFVG
    bullScore += 1
if nearBearFVG
    bearScore += 1

// 3. OB proximity
nearBullOB = false
nearBearOB = false
if bullOBs.size() > 0
    for i = 0 to math.min(bullOBs.size() - 1, 4)
        bx = bullOBs.get(i)
        if close >= bx.get_bottom() and close <= bx.get_top() + ta.atr(14) * 0.5
            nearBullOB := true
            break

if bearOBs.size() > 0
    for i = 0 to math.min(bearOBs.size() - 1, 4)
        bx = bearOBs.get(i)
        if close <= bx.get_top() and close >= bx.get_bottom() - ta.atr(14) * 0.5
            nearBearOB := true
            break

if nearBullOB
    bullScore += 1
if nearBearOB
    bearScore += 1

// 4. Liquidity sweep (high value signal)
if sslSwept
    bullScore += 2  // SSL sweep = bullish setup (double weight)
if bslSwept
    bearScore += 2  // BSL sweep = bearish setup

// 5. Immediate Rebalance
if bullIR
    bullScore += 1
if bearIR
    bearScore += 1

// 6. Killzone active
if inNyAM
    bullScore += 1
    bearScore += 1
else if inLondon
    bullScore += 1
    bearScore += 1

// 7. OTE zone (Fib 0.618-0.786 retracement)
inBullOTE = fibRange > 0 and close >= fib618 and close <= fib786 and msBias == -1 // Retracement in downtrend looking for reversal
inBearOTE = fibRange > 0 and close >= fib236 and close <= fib382 and msBias == 1  // Retracement in uptrend looking for reversal

// Show confluence score
var label scoreLabel = na
if barstate.islast
    label.delete(scoreLabel)
    scoreTxt = "🐺 Confluence\nBull: " + str.tostring(bullScore) + " | Bear: " + str.tostring(bearScore)
    scoreTxt += "\nBias: " + (msBias == 1 ? "🟢 BULLISH" : msBias == -1 ? "🔴 BEARISH" : "⚪ NEUTRAL")
    scoreTxt += "\nKZ: " + (inNyAM ? "NY AM ✅" : inLondon ? "London ✅" : inNyPM ? "NY PM" : inNyLu ? "Lunch ⚠️" : inAsia ? "Asia" : "—")
    scoreLabel := label.new(bar_index + 3, close, scoreTxt,
         color=color.new(color.black, 30), textcolor=color.white,
         style=label.style_label_left, size=size.small)


// ═══════════════════════════════════════════════════════════════
//  🚀 ENTRY LOGIC + WEBHOOK SIGNALS
// ═══════════════════════════════════════════════════════════════

// ─── Trade Count Limit ───
var int todayTrades = 0
newDay = ta.change(time("D"))
if newDay
    todayTrades := 0

canTrade = todayTrades < maxTrades and not noTradeFri and (not useKZfilter or inActiveKZ)

// ─── LONG Entry ───
longCondition = enableAuto and canTrade and bullScore >= minConfl and msBias >= 0 and strategy.position_size == 0

// ─── SHORT Entry ───
shortCondition = enableAuto and canTrade and bearScore >= minConfl and msBias <= 0 and strategy.position_size == 0

// ─── Stop & Target Calculation ───
longStop   = close - riskPts
longTarget = close + riskPts * rrRatio
shortStop  = close + riskPts
shortTarget = close - riskPts * rrRatio

// ─── Webhook Alert Messages ───
longMsg = '{"secret":"' + whSecret + '","action":"buy","symbol":"' + whSymbol + '","qty":' + str.tostring(whQty)
     + ',"price":' + str.tostring(close)
     + ',"stop":' + str.tostring(longStop)
     + ',"target":' + str.tostring(longTarget)
     + ',"strategy":"ICT_MASTER"'
     + ',"timeframe":"' + timeframe.period + '"'
     + ',"comment":"Score:' + str.tostring(bullScore)
     + ' | FVG:' + (nearBullFVG ? "Y" : "N")
     + ' | OB:' + (nearBullOB ? "Y" : "N")
     + ' | SSL_Sweep:' + (sslSwept ? "Y" : "N")
     + ' | IR:' + (bullIR ? "Y" : "N")
     + ' | KZ:' + (inNyAM ? "NYAM" : inLondon ? "LDN" : "OTHER")
     + '"}'

shortMsg = '{"secret":"' + whSecret + '","action":"sell","symbol":"' + whSymbol + '","qty":' + str.tostring(whQty)
     + ',"price":' + str.tostring(close)
     + ',"stop":' + str.tostring(shortStop)
     + ',"target":' + str.tostring(shortTarget)
     + ',"strategy":"ICT_MASTER"'
     + ',"timeframe":"' + timeframe.period + '"'
     + ',"comment":"Score:' + str.tostring(bearScore)
     + ' | FVG:' + (nearBearFVG ? "Y" : "N")
     + ' | OB:' + (nearBearOB ? "Y" : "N")
     + ' | BSL_Sweep:' + (bslSwept ? "Y" : "N")
     + ' | IR:' + (bearIR ? "Y" : "N")
     + ' | KZ:' + (inNyAM ? "NYAM" : inLondon ? "LDN" : "OTHER")
     + '"}'

closeMsg = '{"secret":"' + whSecret + '","action":"close","symbol":"' + whSymbol + '","comment":"Exit signal"}'

// ─── Execute Entries ───
if longCondition
    strategy.entry("Long", strategy.long, alert_message=longMsg)
    todayTrades += 1

if shortCondition
    strategy.entry("Short", strategy.short, alert_message=shortMsg)
    todayTrades += 1

// ─── Exit with stops and targets ───
if strategy.position_size > 0
    strategy.exit("Long Exit", "Long", limit=longTarget, stop=longStop, alert_message=closeMsg)

if strategy.position_size < 0
    strategy.exit("Short Exit", "Short", limit=shortTarget, stop=shortStop, alert_message=closeMsg)

// ─── Force exit outside killzones (optional) ───
if strategy.position_size != 0 and noTradeFri
    strategy.close_all(alert_message=closeMsg)

// ─── Force exit at lunch if still open (Wieland rule) ───
if strategy.position_size != 0 and inNyLu and not inNyLu[1]
    strategy.close_all(comment="Lunch exit", alert_message=closeMsg)


// ═══════════════════════════════════════════════════════════════
//  📊 TABLE — معلومات الجلسة (من Mxwll + TFO)
// ═══════════════════════════════════════════════════════════════

var table infoTab = table.new(position.top_right, 3, 10,
     bgcolor=#1a1a2e, border_color=#2a2a4a, frame_color=#2a2a4a,
     border_width=1, frame_width=1)

if barstate.islast
    // Session
    sessionName = inNyAM ? "NY AM ✅" : inLondon ? "London ✅" : inNyPM ? "NY PM" : inNyLu ? "Lunch ⚠️" : inAsia ? "Asia" : "—"
    table.cell(infoTab, 0, 0, "🐺 DHEEB", text_color=#d4a853, text_size=size.small)
    table.cell(infoTab, 1, 0, "v3.0",      text_color=color.gray, text_size=size.tiny)

    table.cell(infoTab, 0, 1, "Session:",  text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(infoTab, 1, 1, sessionName, text_color=color.white, text_size=size.tiny)

    table.cell(infoTab, 0, 2, "Bias:",     text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(infoTab, 1, 2, msBias == 1 ? "BULL" : msBias == -1 ? "BEAR" : "—",
         text_color=msBias == 1 ? bullC : msBias == -1 ? bearC : color.gray, text_size=size.tiny)

    table.cell(infoTab, 0, 3, "Bull:",     text_color=bullC,       text_size=size.tiny, text_halign=text.align_left)
    table.cell(infoTab, 1, 3, str.tostring(bullScore) + "/7",  text_color=bullC, text_size=size.tiny)

    table.cell(infoTab, 0, 4, "Bear:",     text_color=bearC,       text_size=size.tiny, text_halign=text.align_left)
    table.cell(infoTab, 1, 4, str.tostring(bearScore) + "/7",  text_color=bearC, text_size=size.tiny)

    table.cell(infoTab, 0, 5, "Trades:",   text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(infoTab, 1, 5, str.tostring(todayTrades) + "/" + str.tostring(maxTrades),
         text_color=todayTrades >= maxTrades ? bearC : color.white, text_size=size.tiny)

    table.cell(infoTab, 0, 6, "PDH:",      text_color=color.aqua,  text_size=size.tiny, text_halign=text.align_left)
    table.cell(infoTab, 1, 6, str.tostring(pdH, format.mintick), text_color=color.aqua, text_size=size.tiny)

    table.cell(infoTab, 0, 7, "PDL:",      text_color=color.aqua,  text_size=size.tiny, text_halign=text.align_left)
    table.cell(infoTab, 1, 7, str.tostring(pdL, format.mintick), text_color=color.aqua, text_size=size.tiny)


// ═══════════════════════════════════════════════════════════════
//  🔔 ALERT CONDITIONS
// ═══════════════════════════════════════════════════════════════

alertcondition(longCondition,  "🐺 Long Signal",  "DHEEB LONG: Score {{plot_0}}")
alertcondition(shortCondition, "🐺 Short Signal", "DHEEB SHORT: Score {{plot_0}}")
alertcondition(bullCHoCH,      "Bull CHoCH",       "Bullish CHoCH detected")
alertcondition(bearCHoCH,      "Bear CHoCH",       "Bearish CHoCH detected")
alertcondition(bslSwept,       "BSL Swept",        "Buy-side liquidity swept")
alertcondition(sslSwept,       "SSL Swept",        "Sell-side liquidity swept")
alertcondition(bullIR,         "Bullish IR",        "Bullish Immediate Rebalance")
alertcondition(bearIR,         "Bearish IR",        "Bearish Immediate Rebalance")

// Plot score for alerts
plot(bullScore, "Bull Score", display=display.none)
plot(bearScore, "Bear Score", display=display.none)
