# ═══════════════════════════════════════════════════════════
#  🐺 DHEEB TRADING MIND — Environment Configuration
#  انسخ هذا الملف إلى .env وعبّئ بياناتك
# ═══════════════════════════════════════════════════════════

# ─── Tradovate API ───
TRADOVATE_USER=your_username
TRADOVATE_PASS=your_password
TRADOVATE_CID=your_client_id
TRADOVATE_SEC=your_secret_key
TRADOVATE_DEVICE_ID=dheeb-device-001
TRADOVATE_DEMO=true

# ─── NQ Contract Symbol ───
# Format: NQ + Month Code + Year (e.g., NQH6 = March 2026)
# H=Mar, M=Jun, U=Sep, Z=Dec
NQ_SYMBOL=NQH6
MNQ_SYMBOL=MNQH6

# ─── Webhook Server ───
WEBHOOK_PORT=3000
WEBHOOK_SECRET=your_strong_secret_key_here

# ─── Account Profile ───
ACCOUNT_PROFILE=small
# small = $50K funded account
# medium = $150K funded account

# ─── Telegram Notifications (Optional) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Logging ───
LOG_LEVEL=info
LOG_FILE=./logs/dheeb.log
